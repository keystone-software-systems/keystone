# Resend API key used by app/api/contact/route.ts
RESEND_API_KEY=

# Verified "from" sender for outgoing contact-form emails.
# Defaults to Resend's shared test domain until stackdiligence.com is verified in Resend.
RESEND_FROM_EMAIL="StackDiligence <onboarding@resend.dev>"

# Destination inbox for contact-form submissions.
# Defaults to tanner@propdog.ai until a @stackdiligence.com inbox exists.
CONTACT_TO_EMAIL=tanner@propdog.ai
